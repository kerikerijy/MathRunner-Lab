---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/MathRunner-Lab/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <meta name="description" content="数学をもっと楽しく。教育アプリ開発者のポートフォリオサイト。">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link
            href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600&family=M+PLUS+Rounded+1c:wght@500;800&display=swap"
            rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
    :root {
        --pop-orange: #FF9F1C;
        --pop-blue: #2EC4B6;
        --pop-yellow: #FFBF69;
        --pop-dark: #333333;
        --pop-white: #FFFFFF;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        margin: 0;
        width: 100%;
        height: 100%;
    }

    body {
        font-family: 'M PLUS Rounded 1c', 'Fredoka', sans-serif;
        color: var(--pop-dark);
        background-color: #FAFAFA;
        min-height: 100vh;
        overflow-x: hidden;
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
