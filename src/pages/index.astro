---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MathRunner Lab | 学びをもっと楽しく">
    <div class="fixed-bg"></div>

    <div class="container">
        <header>
            <div class="header-deco">
                <h1>MathRunner Lab</h1>
                <p class="tagline">学びをもっと楽しく、もっと身近に。🚀</p>
                <p class="english-tagline">Prototyping learning, one run at a time.</p>
            </div>
        </header>

        <div class="apps-grid">
            <!-- App 0: 座席ますたー (New) -->
            <a href="https://apps.apple.com/jp/app/%E5%BA%A7%E5%B8%AD%E3%81%BE%E3%81%99%E3%81%9F%E3%83%BC/id6758137498"
                target="_blank" class="app-card">
                <div class="card-header">
                    <img src="https://is1-ssl.mzstatic.com/image/thumb/Purple211/v4/b4/8f/28/b48f28bc-e2a9-0cae-6622-c7253ae59043/AppIcon-0-0-1x_U007epad-0-1-85-220.png/100x100bb.jpg"
                        alt="Icon" class="app-icon">
                    <div class="app-title">座席ますたー</div>
                </div>
                <p class="app-desc">クラス管理をもっと楽しく！iPad専用の高度な席替え＆出欠管理アプリ。先生の業務を強力にサポート。</p>
                <div class="badges">
                    <span class="badge bg-education">教育</span>
                    <span class="badge" style="background: var(--pop-dark); color: white; cursor: pointer;" onclick="event.preventDefault(); window.location.href='/MathRunner-Lab/seating-master-manual';">マニュアル</span>
                </div>
            </a>

            <!-- App 1: 三角比ますたー -->
            <a href="https://apps.apple.com/jp/app/%E4%B8%89%E8%A7%92%E6%AF%94%E3%81%BE%E3%81%99%E3%81%9F%E3%83%BC/id1640664452"
                target="_blank" class="app-card">
                <div class="card-header">
                    <img src="https://is1-ssl.mzstatic.com/image/thumb/Purple221/v4/78/91/b7/7891b75d-be9f-26c4-88fb-d6f6636c379f/AppIcon-0-0-1x_U007epad-0-1-sRGB-85-220.png/100x100bb.jpg"
                        alt="Icon" class="app-icon" />
                    <div class="app-title">三角比ますたー</div>
                </div>
                <p class="app-desc">単位円をくるくる回して三角比を直感理解！クイズ形式でサクサク進める、高校数学の決定版アプリ。</p>
                <div class="badges">
                    <span class="badge bg-education">教育</span>
                    <span class="badge bg-free">無料</span>
                </div>
            </a>

            <!-- App 2: 積分ますたー -->
            <a href="https://apps.apple.com/jp/app/%E7%A9%8D%E5%88%86%E3%81%BE%E3%81%99%E3%81%9F%E3%83%BC/id6736927178"
                target="_blank" class="app-card">
                <div class="card-header">
                    <img src="https://is1-ssl.mzstatic.com/image/thumb/Purple221/v4/ac/00/79/ac0079a3-ae10-ef26-43e5-ce3f82e1f1c1/AppIcon-0-0-1x_U007epad-0-1-85-220.png/100x100bb.jpg"
                        alt="Icon" class="app-icon" />
                    <div class="app-title">積分ますたー</div>
                </div>
                <p class="app-desc">パズルのように積分を解こう。豊富な問題数で、計算力がメキメキ上がる！</p>
                <div class="badges">
                    <span class="badge bg-education">教育</span>
                    <span class="badge bg-free">無料</span>
                </div>
            </a>

            <!-- App 3: 合同式ますたー -->
            <a href="https://apps.apple.com/jp/app/%E5%90%88%E5%90%8C%E5%BC%8F%E3%81%BE%E3%81%99%E3%81%9F%E3%83%BC/id6474422643"
                target="_blank" class="app-card">
                <div class="card-header">
                    <img src="https://is1-ssl.mzstatic.com/image/thumb/Purple126/v4/c9/f4/d2/c9f4d2e0-16e8-6947-a171-e0ce2fa69780/AppIcon-0-0-1x_U007epad-0-85-220.png/100x100bb.jpg"
                        alt="Icon" class="app-icon" />
                    <div class="app-title">合同式ますたー</div>
                </div>
                <p class="app-desc">整数問題のカギ、合同式（Mod）をマスター。数学オリンピックやアルゴリズムの基礎固めに。</p>
                <div class="badges">
                    <span class="badge bg-education">教育</span>
                    <span class="badge bg-free">無料</span>
                </div>
            </a>

            <!-- App 4: カンタン席替え -->
            <a href="https://apps.apple.com/jp/app/%E3%82%AB%E3%83%B3%E3%82%BF%E3%83%B3%E5%B8%AD%E6%9B%BF%E3%81%88/id1640634924"
                target="_blank" class="app-card">
                <div class="card-header">
                    <img src="https://is1-ssl.mzstatic.com/image/thumb/Purple122/v4/a2/86/03/a286031d-0b15-2209-62a7-d19f04fb4763/AppIcon-1x_U007emarketing-0-4-sRGB-85-220.png/100x100bb.jpg"
                        alt="Icon" class="app-icon" />
                    <div class="app-title">カンタン席替え</div>
                </div>
                <p class="app-desc">先生の味方！面倒な席替えを一瞬で。条件設定もできる高機能な席替えルーレット。</p>
                <div class="badges">
                    <span class="badge bg-utility">ユーティリティ</span>
                    <span class="badge bg-free">無料</span>
                </div>
            </a>

            <!-- App 5: 数字を順番に押す -->
            <a href="https://apps.apple.com/jp/app/%E6%95%B0%E5%AD%97%E3%82%92%E9%A0%86%E7%95%AA%E3%81%AB%E6%8A%BC%E3%81%99/id6443621796"
                target="_blank" class="app-card">
                <div class="card-header">
                    <img src="https://is1-ssl.mzstatic.com/image/thumb/Purple112/v4/22/36/17/223617d7-287a-da1c-65eb-3b5ceba19a18/AppIcon-1x_U007emarketing-0-7-0-85-220.png/100x100bb.jpg"
                        alt="Icon" class="app-icon" />
                    <div class="app-title">数字を順番に押す</div>
                </div>
                <p class="app-desc">シンプルだけどハマる！脳トレや周辺視野トレーニングに最適なミニゲーム。</p>
                <div class="badges">
                    <span class="badge bg-game">ゲーム</span>
                    <span class="badge bg-free">無料</span>
                </div>
            </a>
        </div>

        <footer>
            <div class="coming-soon">📬 Contact & SNS: Coming Soon...</div>
            <p style="margin-top: 2rem; color: #777;">© 2026 MathRunner Lab</p>
        </footer>
    </div>
</Layout>

<style>
/* Hero Background */
.fixed-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background-image: url('/MathRunner-Lab/bg_pop.png');
    background-size: cover;
    background-position: center;
    opacity: 0.15;
}

/* Container */
.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
    position: relative;
}

/* Header */
header {
    text-align: center;
    padding: 5rem 1rem 3rem;
}

.header-deco {
    display: inline-block;
    background: var(--pop-white);
    border: 4px solid var(--pop-dark);
    box-shadow: 8px 8px 0px var(--pop-orange);
    padding: 2.5rem 4rem;
    border-radius: 20px;
    transform: rotate(-2deg);
    transition: transform 0.3s ease;
}

.header-deco:hover {
    transform: rotate(0deg) scale(1.02);
    box-shadow: 12px 12px 0px var(--pop-blue);
}

h1 {
    font-size: 3rem;
    color: var(--pop-dark);
    margin-bottom: 0.5rem;
    font-weight: 800;
    letter-spacing: 0.05em;
}

.tagline {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--pop-blue);
    margin-bottom: 0.5rem;
}

.english-tagline {
    font-size: 0.9rem;
    color: #777;
    font-family: 'Fredoka', sans-serif;
}

/* Apps Grid */
.apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    padding-bottom: 4rem;
}

.app-card {
    background: var(--pop-white);
    border: 3px solid var(--pop-dark);
    border-radius: 20px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease-in-out;
    box-shadow: 6px 6px 0px var(--pop-dark);
    display: flex;
    flex-direction: column;
    position: relative;
    top: 0;
    left: 0;
}

.app-card:hover {
    top: -4px;
    left: -4px;
    box-shadow: 10px 10px 0px var(--pop-orange);
}

.app-card:nth-child(2n):hover {
    box-shadow: 10px 10px 0px var(--pop-blue);
}

.app-card:nth-child(3n):hover {
    box-shadow: 10px 10px 0px var(--pop-yellow);
}

.card-header {
    display: flex;
    align-items: center;
    margin-bottom: 1rem;
    gap: 1rem;
}

.app-icon {
    width: 72px;
    height: 72px;
    border-radius: 16px;
    border: 2px solid var(--pop-dark);
}

.app-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--pop-dark);
}

.app-desc {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 1.5rem;
    font-weight: 500;
}

.badges {
    display: flex;
    gap: 0.5rem;
}

.badge {
    font-size: 0.8rem;
    padding: 0.4rem 1rem;
    border-radius: 30px;
    font-weight: 800;
    border: 2px solid var(--pop-dark);
}

.bg-education { background: #E0F7FA; color: #006064; }
.bg-game { background: #FFF3E0; color: #E65100; }
.bg-utility { background: #E8F5E9; color: #1B5E20; }
.bg-free { background: var(--pop-yellow); color: var(--pop-dark); }

/* Footer */
footer {
    text-align: center;
    padding: 3rem;
    color: var(--pop-dark);
    font-weight: 700;
}

/* Coming Soon */
.coming-soon {
    background: var(--pop-dark);
    color: var(--pop-white);
    border-radius: 50px;
    padding: 0.8rem 2rem;
    display: inline-block;
    margin-top: 2rem;
    font-size: 1rem;
    font-weight: 700;
    box-shadow: 4px 4px 0px #AAA;
    transform: rotate(2deg);
}

@media (max-width: 600px) {
    h1 { font-size: 2.2rem; }
    .header-deco {
        padding: 2rem 1.5rem;
        width: 100%;
        transform: rotate(0deg);
    }
    .apps-grid { gap: 1.5rem; }
}
</style>
